# Copy this to `.env.local` to connect the front end to the GramSynth backend.
#
# Point it at the orchestration API (server/). When set, the pipeline stages
# stream REAL telemetry over Server-Sent Events. When unset/empty, the app runs
# its built-in offline simulation and needs no backend.
#
# Local backend:
# VITE_API_BASE=http://localhost:8000
#
# Remote GPU (e.g. vast.ai) reached through an SSH tunnel on port 8000:
# VITE_API_BASE=http://localhost:8000
